# ai-chat.eduardoinerarte.dk — example nginx vhost.
#
# This file lives under .github/nginx/ so the deploy workflow can
# diff it against what's on the server. The actual file on the
# server is /etc/nginx/sites-available/ai-chat.eduardoinerarte.dk.conf
# (this template is the upstream copy).
#
# Apply once:
#   1. sudo cp this file /etc/nginx/sites-available/ai-chat.eduardoinerarte.dk.conf
#   2. sudo ln -s ../sites-available/ai-chat.eduardoinerarte.dk.conf \
#             /etc/nginx/sites-enabled/ai-chat.eduardoinerarte.dk.conf
#   3. sudo nginx -t && sudo systemctl reload nginx
#
# Prerequisites on the server:
#   - /var/www/ai-chat.eduardoinerarte.dk/ exists and is writable by the
#     user named in HETZNER_USER.
#   - The wildcard TLS cert and key are at the usual path
#     /etc/letsencrypt/live/eduardoinerarte.dk/ (one cert, multiple
#     server names; nginx -SNI handles the rest).
#   - A CNAME or wildcard A record (*.eduardoinerarte.dk) points to
#     this server's public IP.
#
# What this config does:
#   - Serves static files from /var/www/.../ with hashed-name assets
#     (e.g. /assets/index-abc.js) cached for 1 year, immutable.
#   - The entry-point HTML (index.html, favicon) gets no-cache, so
#     a fresh deploy is visible immediately on next request.
#   - SPA fallback: any path that does not match a file falls back to
#     /index.html so client-side routing works.
#   - Shared wildcard TLS with the rest of eduardoinerarte.dk.
#
# What this config does NOT do:
#   - Run a Node server. The demo is a static SPA; it can be served
#     by nginx alone.
#   - Provision TLS. The wildcard cert is already on the server.

# HTTP -> HTTPS redirect for this host only.
server {
    listen 80;
    listen [::]:80;
    server_name ai-chat.eduardoinerarte.dk;

    # ACME http-01 challenge goes through here. certbot places a
    # file under /.well-known/acme-challenge/ on the *next* server
    # block; or for a wildcard we don't issue here at all. Keep
    # this block thin.
    location /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name ai-chat.eduardoinerarte.dk;

    # Wildcard TLS cert. Same cert is reused by *.eduardoinerarte.dk.
    ssl_certificate     /etc/letsencrypt/live/eduardoinerarte.dk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/eduardoinerarte.dk/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Security headers. Don't conflict with the package's own UI — the
    # chat panel may inline images and JSON; X-Content-Type-Options:
    # nosniff is safe; X-Frame-Options blocks the page from being
    # framed on other origins.
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    root /var/www/ai-chat.eduardoinerarte.dk;
    index index.html;

    # Hashed assets: long cache. The dist/ output names its files
    # with content hashes, so we can cache them forever safely.
    location /assets/ {
        access_log off;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        try_files $uri =404;
    }

    # Index + favicon: short cache so deploys are visible immediately.
    location = /index.html {
        add_header Cache-Control "no-cache, must-revalidate" always;
    }

    # SPA fallback. Any GET that does not match a static file gets
    # the SPA shell. We do NOT fallback for /assets/ because those
    # must 404 if missing (handled by the rule above).
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Hide dotfiles just in case.
    location ~ /\. {
        deny all;
    }

    # Reasonable timeouts. The app is a SPA, no remote calls during
    # serving (those go to the user's browser -> their LLM provider).
    keepalive_timeout 65;
    client_max_body_size 25m;
}
