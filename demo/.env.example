# Copy this file to .env and paste your MiniMax key from platform.minimaxi.chat.
# Vite only injects env vars prefixed with VITE_ at build / dev time; the
# ai-schadcn-chat package reads both the VITE_-prefixed copies (via
# import.meta.env) and the un-prefixed names (also via import.meta.env after
# the demo bridges them).
VITE_MINIMAX_API_KEY=
VITE_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
VITE_MINIMAX_MODEL=MiniMax-M3

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M3