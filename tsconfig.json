{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "resolvePackageJsonExports": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@edd_remonts/ai-schadcn-chat": ["./src/index.ts"],
      "@edd_remonts/ai-schadcn-chat/hooks": ["./src/hooks/index.ts"],
      "@edd_remonts/ai-schadcn-chat/providers": ["./src/providers/index.ts"],
      "@edd_remonts/ai-schadcn-chat/lib": ["./src/lib/index.ts"],
      "@edd_remonts/ai-schadcn-chat/types": ["./src/types/index.ts"],
      "@edd_remonts/ai-schadcn-chat/components": ["./src/components/index.ts"]
    }
  },
  "include": ["src", "demo", "scripts"],
  "exclude": ["node_modules", "dist", "vitest.config.ts"]
}